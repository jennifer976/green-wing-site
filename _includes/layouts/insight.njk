---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="container prose-wide">
    <p class="back-link"><a href="{{ root }}insights.html">← Insights</a></p>
    <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
    <h1>{{ title }}</h1>
  </div>
</section>

<section class="page-section">
  <div class="container prose-wide prose">
    {% if image %}
    <figure class="article-hero-image">
      <img src="{{ image | assetPath(root) }}" alt="{{ imageAlt or title }}" loading="lazy">
    </figure>
    {% endif %}
    {% if showScopeInfographic %}
      {% include "partials/scope-infographic.njk" %}
    {% endif %}
    {{ content | safe }}
    {% set shareUrl = 'https://greenwingenergysolutions.com' + page.url %}
    {% set shareTitle = title + ' | Green Wing Energy Solutions' %}
    <aside class="article-share" aria-label="Share this article">
      <h2>Share this insight</h2>
      <div class="article-share-links">
        <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ shareUrl | urlEncode }}" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ shareUrl | urlEncode }}" target="_blank" rel="noopener noreferrer">Facebook</a>
        <a href="https://twitter.com/intent/tweet?url={{ shareUrl | urlEncode }}&text={{ shareTitle | urlEncode }}" target="_blank" rel="noopener noreferrer">X</a>
        <a href="mailto:?subject={{ shareTitle | urlEncode }}&body={{ shareUrl | urlEncode }}">Email</a>
        <button type="button" data-copy-link="{{ shareUrl }}">Copy link</button>
      </div>
      <p class="article-share-status" aria-live="polite"></p>
    </aside>
    <p>
      <a href="{{ root }}contact.html" class="btn btn-solid btn-arrow">Arrange an Energy Review</a>
      <span class="cta-micro" style="display:block; margin-top:0.5rem;">Start with a free 15-minute discovery call.</span>
    </p>
    {% set related = collections.insightsSorted | relatedInsights(page.url) %}
    {% if related.length %}
    <aside class="related-posts">
      <h2>More insights</h2>
      <ul>
        {% for post in related %}
        <li><a href="{{ root }}insights/{{ post.fileSlugStem }}.html">{{ post.data.title }}</a></li>
        {% endfor %}
      </ul>
    </aside>
    {% endif %}
  </div>
</section>

{% include "partials/cta-band.njk" %}
