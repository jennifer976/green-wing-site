---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="container prose-wide">
    <p class="back-link"><a href="{{ root }}insights.html">← Insights</a></p>
    <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
    <h1>{{ title }}</h1>
  </div>
</section>

<section class="page-section">
  <div class="container prose-wide prose">
    {% if image %}
    <figure class="article-hero-image" style="--image-fit: {{ imageFit or 'cover' }}; --image-position: {{ imagePosition or 'center center' }}; --image-zoom: {{ imageZoom or 1 }};">
      <img src="{{ image | assetPath(root) }}" alt="{{ imageAlt or title }}" loading="lazy">
    </figure>
    {% endif %}
    {% if showScopeInfographic %}
      {% include "partials/scope-infographic.njk" %}
    {% endif %}
    {{ content | safe }}
    <p><a href="{{ root }}contact.html" class="btn btn-solid btn-arrow">Arrange an Energy Review</a></p>
    {% set related = collections.insightsSorted | relatedInsights(page.url) %}
    {% if related.length %}
    <aside class="related-posts">
      <h2>More insights</h2>
      <ul>
        {% for post in related %}
        <li><a href="{{ root }}insights/{{ post.fileSlugStem }}.html">{{ post.data.title }}</a></li>
        {% endfor %}
      </ul>
    </aside>
    {% endif %}
  </div>
</section>

{% include "partials/cta-band.njk" %}
